RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_LOGIN=admin
RABBIT_PASS=password
RABBIT_CONNECT_RETRIES=30
RABBIT_CONNECT_RETRY_DELAY_SECONDS=2
LOG_LEVEL=INFO

JOB_REPOSITORY_BACKEND=postgres
TASK_REPOSITORY_BACKEND=postgres
WORKER_REPOSITORY_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://mapreduce:mapreduce_password@localhost:5432/mapreduce

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=mapreduce-data

RUNNING_TASK_TIMEOUT_SECONDS=300
RUNNING_TASK_TIMEOUT_CHECK_SECONDS=30
WORKER_HEARTBEAT_TIMEOUT_SECONDS=15
WORKER_HEARTBEAT_TIMEOUT_CHECK_SECONDS=5
